# ─────────────────────────────────────────────────────────────────────────────
# govd-bot — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=12345678:ABC-DEF1234ghIkl-zyx57W2P0s

# ── Telegram Bot API (use official or self-hosted) ────────────────────────────
BOT_API_URL=https://api.telegram.org

# How many simultaneous updates to process (increase for busy bots)
CONCURRENT_UPDATES=50

# ── Storage ───────────────────────────────────────────────────────────────────
DOWNLOADS_DIR=downloads
DB_PATH=govd_bot.db

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=2000       # in MB (Telegram limit is 2000 MB for local API)
MAX_DURATION=1h          # e.g. 1h, 30m, 15s

# ── Defaults per chat ─────────────────────────────────────────────────────────
DEFAULT_ENABLE_CAPTIONS=true
DEFAULT_ENABLE_SILENT=false
DEFAULT_ENABLE_NSFW=false
DEFAULT_MEDIA_ALBUM_LIMIT=10
DEFAULT_LANGUAGE=en       # en | ar (add more in utils/i18n.py)

# ── Caption format (HTML) ─────────────────────────────────────────────────────
# {url} is replaced with the source URL
CAPTIONS_HEADER=<a href='{url}'>source</a>
CAPTIONS_DESCRIPTION=<blockquote expandable>{text}</blockquote>

# ── Proxy (http, https, socks5) ───────────────────────────────────────────────
# PROXY=socks5://user:pass@host:1080
# PROXY=http://proxy:8080

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs. Leave empty to allow everyone.
WHITELIST=
# Bot admins (can use /stats, /broadcast, /whitelist)
ADMINS=

# ── Misc ──────────────────────────────────────────────────────────────────────
CACHING=true
LOG_LEVEL=INFO
AUTOMATIC_LANGUAGE_DETECTION=true
REPO_URL=https://github.com/IIDZII-Dev/govd-bot
